# Discord
DISCORD_TOKEN=
# Optional: restrict to a channel id
DISCORD_ALLOW_CHANNEL_ID=

# Telegram
TELEGRAM_TOKEN=

# Feishu (Lark)
# - This uses Event Subscription (webhook) mode.
# - Configure your Feishu app to send events to:
#   http(s)://<host>:FEISHU_LISTEN_PORT/feishu/events
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# Optional: validate incoming events
FEISHU_VERIFICATION_TOKEN=
# Webhook listener port
FEISHU_LISTEN_PORT=3030

# Agent command (stdio ACP)
# Default: Codex via Zed adapter (ACP stdio)
# - Agent reads JSON-RPC lines from stdin, writes JSON-RPC lines to stdout.
# Refs:
#   https://agentclientprotocol.com/protocol/transports
ACP_AGENT_COMMAND=npx
ACP_AGENT_ARGS=-y @zed-industries/codex-acp@latest

# Workspace root for fs/terminal tool calls (absolute path)
WORKSPACE_ROOT=/tmp/cli-gateway-workspace

# DB path
DB_PATH=.data/gateway.db

# Scheduler
SCHEDULER_ENABLED=true

# Runtime limits
# - Each conversation binding spawns its own ACP stdio agent process.
RUNTIME_IDLE_TTL_SECONDS=900
MAX_BINDING_RUNTIMES=30

# Context replay ("memory")
# - Only used when the binding runtime creates a fresh ACP session
#   (e.g. after restart or idle GC).
CONTEXT_REPLAY_ENABLED=true
CONTEXT_REPLAY_RUNS=8
CONTEXT_REPLAY_MAX_CHARS=12000
